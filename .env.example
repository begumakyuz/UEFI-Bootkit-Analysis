# UEFI Analysis / Gitea Environment Configuration (EXAMPLE)
# DO NOT PUT REAL SECRETS IN HERE

# Docker Compose Settings
COMPOSE_PROJECT_NAME=uefi_gitea_analyzer
DOCKER_PORT=3000

# CI/CD & Analysis Settings
ANALYSIS_MODE=strict
YARA_RULES_PATH=./yara/blacklotus_bootkit.yar
TARGET_FIRMWARE_DIR=./assets/
DEBUG_LOGS=true

# Mock Auth Parameters for Thread Modeling
AUTH_BYPASS_SIMULATION=enabled
MOCK_ADMIN_TOKEN=example_token_12345
